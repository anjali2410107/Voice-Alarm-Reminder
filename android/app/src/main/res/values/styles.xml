<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 
        LaunchTheme: The "SplashScreen" theme. 
        Using AppCompat for better trusted connection with Samsung Lockscreen.
    -->
    <style name="LaunchTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        
        <!-- Official Android 8.0+ Lock Screen attributes -->
        <item name="android:showWhenLocked">true</item>
        <item name="android:turnScreenOn">true</item>
    </style>

    <!-- 
        NormalTheme: The theme applied after the splash screen finishes.
        Must match LaunchTheme attributes to prevent "flickering" or permission loss.
    -->
    <style name="NormalTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">?android:colorBackground</item>
        
        <!-- Official Android 8.0+ Lock Screen attributes -->
        <item name="android:showWhenLocked">true</item>
        <item name="android:turnScreenOn">true</item>
    </style>
</resources>
